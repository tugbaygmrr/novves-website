    "tag": "FAQ",
    "title": "Frequently Asked Questions",
    "items": [
      {
        "q": "Which industries does NOVVES serve?",
        "a": "NOVVES provides smoke extraction, comfort ventilation, and industrial air management solutions across a wide range of sectors including parking garages, tunnels, shopping malls, hospitals, hotels, industrial facilities, greenhouses, power plants, and residential buildings."
      },
      {
        "q": "Which standards do your products comply with?",
        "a": "Our products are manufactured in compliance with EN 12101-3, ISO 9001, ISO 14001, ISO 45001, CE, and ATEX standards, and are tested in accredited laboratories."
      },
      {
        "q": "Do you provide CFD analysis services?",
        "a": "Yes, we perform 3D CFD simulations for each project to analyze smoke propagation, temperature, CO concentration, and visibility distance, optimizing jet fan placement."
      },
      {
        "q": "Do you offer after-sales support?",
        "a": "We provide comprehensive after-sales support including commissioning, periodic maintenance, spare parts supply, and 24/7 technical service."
      }
    ]
